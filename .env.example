# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Base URL of the Pact Broker (self-hosted or PactFlow) where contracts are
# published and fetched. For the dockerised broker in CI, this is http://localhost:9292.
PACT_BROKER_BASE_URL=https://your-org.pactflow.io

# Read/write API token used to authenticate publish and verification calls.
PACT_BROKER_TOKEN=pactflow-xxxxxxxxxxxxxxxx

# Version tagged on published pacts — use the git commit SHA so contracts are
# traceable to a build.
CONSUMER_VERSION=a1b2c3d

# Version recorded for provider verification results — also the git commit SHA
# of the provider build.
PROVIDER_VERSION=e4f5g6h

# Branch name attached to published pacts and verifications so the broker can
# reason about branches. Optional.
PACT_BRANCH=main

# URL the provider verifier targets when replaying interactions against the
# running API. Optional — defaults to http://127.0.0.1:3001.
PROVIDER_BASE_URL=http://localhost:3001
