{
  "name": "qacodes-pact-contract-testing",
  "version": "1.0.0",
  "description": "Consumer-driven contract testing with Pact and TypeScript — an Order UI consumer and an Orders API provider wired through a Pact Broker.",
  "license": "MIT",
  "author": "qa.codes",
  "private": true,
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "scripts": {
    "test:consumer": "jest --config jest.consumer.config.js --runInBand",
    "test:provider": "jest --config jest.provider.config.js --runInBand",
    "pact:publish": "ts-node scripts/publish-pacts.ts",
    "can-i-deploy": "pact-broker can-i-deploy --pacticipant OrdersApi --version $PROVIDER_VERSION --to-environment production",
    "record-deployment": "pact-broker record-deployment --pacticipant OrdersApi --version $PROVIDER_VERSION --environment production",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^12.5.2",
    "@pact-foundation/pact-cli": "^18.1.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
