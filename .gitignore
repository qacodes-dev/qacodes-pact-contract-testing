.env
.env.local

# Pact artifacts: pact files are generated by the consumer suite and published
# to the broker in CI — the broker is the source of truth, not git. Keep the
# directory (.gitkeep) but ignore generated contracts and logs.
logs/
pacts/*.json
pacts/*.log

